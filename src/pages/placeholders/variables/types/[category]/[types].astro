---
import { buildFunctionsSidebar, getFunctionPages, getVariablePages } from "@src/utils/functions-sidebar-utils";
import StarlightPage from "@astrojs/starlight/components/StarlightPage.astro";
import PlaceholderPage from "@src/components/react/placeholders/page/PlaceholderPage";
import type { I18nKeys } from "node_modules/@astrojs/starlight/utils/createTranslationSystem";

export const pages = getVariablePages("/placeholders/variables/types/");

export async function getStaticPaths() {
   return pages.map((page) => ({
      params: {
         category: page.category.toLowerCase(),
         types: page.label,
      },
      props: {
         desc: page.description,
      },
   }));
}

const { category, types } = Astro.params;
const { desc } = Astro.props;

const { sidebarGroups } = buildFunctionsSidebar(pages, (key) => Astro.locals?.t(("placeholder.variable." + key) as I18nKeys));
---

<StarlightPage
   frontmatter={{ title: `${types}`, description: desc }}
   sidebar={[
      {
         label: Astro.locals?.t("placeholder.variable.title" as I18nKeys),
         items: sidebarGroups,
      },
   ]}
>
   <PlaceholderPage
      client:visible
      type="variable"
      category={category}
      name={types}
   />
</StarlightPage>
