---
import { buildFunctionsSidebar, getFunctionPages } from "@src/utils/functions-sidebar-utils";
import StarlightPage from "@astrojs/starlight/components/StarlightPage.astro";
import ReactFnPage from "@src/components/react/functions/ReactFnPage";
import type { I18nKeys } from "node_modules/@astrojs/starlight/utils/createTranslationSystem";

export const pages = getFunctionPages("/placeholders/functions/types/");

export async function getStaticPaths() {
   return pages.map((page) => ({
      params: {
         category: page.category.toLowerCase(),
         types: page.label,
      },
      props: {
         desc: page.description,
      },
   }));
}

const { category, types } = Astro.params;
const { desc } = Astro.props;

const { sidebarGroups } = buildFunctionsSidebar(pages, (key) => Astro.locals?.t(key as I18nKeys));
---

<StarlightPage
   frontmatter={{ title: `${types}`, description: desc }}
   sidebar={[
      {
         label: Astro.locals?.t("placeholder.function.title" as I18nKeys),
         items: sidebarGroups,
      },
   ]}
>
   <ReactFnPage
      client:visible
      fnCategory={category}
      fnName={types}
   />
</StarlightPage>
