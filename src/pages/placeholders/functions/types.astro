---
import { buildFunctionsSidebar, getFunctionPages } from "@src/utils/functions-sidebar-utils";
import StarlightPage from "@astrojs/starlight/components/StarlightPage.astro";
import CodeVar from "@src/components/CodeVar.astro";
import type { I18nKeys } from "node_modules/@astrojs/starlight/utils/createTranslationSystem";
import { pathHasLocale } from "astro:i18n";

const pages = getFunctionPages("/placeholders/functions/types/");

const { sidebarGroups } = buildFunctionsSidebar(pages, (key) => Astro.locals?.t(key as I18nKeys));
---

<StarlightPage
   frontmatter={{
      title: Astro.locals?.t("placeholder.function.title" as I18nKeys),
      description: Astro.locals?.t("placeholder.function.description" as I18nKeys),
      pageLink: {
         label: Astro.locals?.t("placeholder.function.pagelink.categories" as I18nKeys),
         href: "/placeholders/functions/",
      },
      next: {
         link: "/placeholders/functions/types/debug/Log/",
         label: pages[0].label,
      },
   }}
   sidebar={[
      {
         label: Astro.locals?.t("placeholder.function.title" as I18nKeys),
         items: sidebarGroups,
      },
   ]}
>
   <h1>Todas as funções</h1>
   <table>
      <tr>
         <th>VARIÁVEIS</th>
         <th>RETORNOS</th>
      </tr>
      {
         pages.map((p) => (
            <tr>
               <td>
                  <CodeVar>{p.label}</CodeVar>
               </td>
               <td class="description">
                  <a
                     class="function-item"
                     href={p.link}
                  >
                     {p.description}
                     {p.version && (
                        <span
                           class="version"
                           title={p.version}
                        >
                           {p.version}+
                        </span>
                     )}
                  </a>
               </td>
            </tr>
         ))
      }
   </table>
</StarlightPage>

<style>
   div,
   a,
   p {
      margin: 0;
   }
   .function-container {
      display: flex;
      flex-direction: column;
      gap: 1rem;
   }
   .function-item {
      overflow: hidden;
      max-width: fit-content;
      gap: 0.5em;
      padding: 5px;
      cursor: pointer;
      text-decoration: none;
      color: inherit;
   }

   .function-item:hover {
      color: var(--sl-color-accent-high);
   }
   .description {
      position: relative;
   }
   .version {
      position: absolute;
      right: 8px;
      top: 50%;
      transform: translateY(-50%);
      display: inline-block;
      color: var(--sl-color-accent);
      font-size: 15px;
      font-weight: semi-bold;
   }
</style>
