---
import { FUNCTION_MAPPING } from "@src/data/functions-data";
import CodeVar from "@components/CodeVar.astro";
import { Eye } from "lucide-react";
import PlaceholderModal from "./react/placeholders/modal/PlaceholderModal";
import { VARIABLE_MAPPING } from "@src/data/variables-data";

const { type, category } = Astro.props;

const MAPPING = type === "function" ? FUNCTION_MAPPING : VARIABLE_MAPPING;

const elements = MAPPING.get(category) && Array.from(MAPPING.get(category)!.values());

const containsAliases =
   elements &&
   elements.find((fn) => {
      return fn.aliases;
   });
---

{
   elements && (
      <table>
         <thead>
            <tr>
               <th>PLACEHOLDERS</th>
               {containsAliases && <th class="aliases">ALIASES</th>}
               <th>RETORNOS</th>
            </tr>
         </thead>
         <tbody>
            {elements.map((fn) => (
               <tr>
                  <td>
                     <div class="name-container">
                        <CodeVar copy={fn.name}>{fn.name}</CodeVar>
                        {fn.aliases && (
                           <div class="aliases-mobile">
                              <CodeVar copy={fn.aliases}>{fn.aliases}</CodeVar>
                           </div>
                        )}
                     </div>
                  </td>
                  {containsAliases && <td class="aliases">{fn.aliases && <CodeVar copy={fn.aliases}>{fn.aliases}</CodeVar>}</td>}
                  <td>
                     <PlaceholderModal
                        client:visible
                        type={type}
                        category={fn.category}
                        name={fn.name}
                     >
                        <div class="description">
                           <p
                              class="text"
                              title={fn.description.full}
                           >
                              {fn.description.simple}
                           </p>
                           <div class="badge-wrapper">
                              {fn.version && (
                                 <span
                                    class="version"
                                    title={fn.version}
                                 >
                                    {fn.version}+
                                 </span>
                              )}
                              <div class="redirect-icon">
                                 <Eye
                                    size="1.5rem"
                                    strokeWidth="1.1px"
                                 />
                              </div>
                           </div>
                        </div>
                     </PlaceholderModal>
                  </td>
               </tr>
            ))}
         </tbody>
      </table>
   )
}

<!-- Estilos -->
<style>
   td {
      vertical-align: middle;
   }
   p,
   svg {
      margin: 0;
      padding: 0;
   }
   .description {
      position: relative;
      display: flex;
      flex-direction: row;
      height: 100%;
      align-items: center;
   }

   .description:active {
      color: var(--sl-color-accent);
   }

   .badge-wrapper {
      position: absolute;
      top: 50%;
      transform: translateY(-50%);
      right: 8px;
      display: flex;
      align-items: center;
      gap: 8px;
   }

   .version {
      display: inline-block;
      color: var(--sl-color-accent);
      font-size: 15px;
      font-weight: semi-bold;
   }

   .redirect-icon {
      margin: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      opacity: 0.1;
      height: 100%;
   }

   .aliases-mobile {
      display: none;
   }
   @media (max-width: 950px) {
      .aliases {
         display: none;
      }
      .aliases-mobile {
         display: block;
         margin-top: 5px;
      }
   }

   @media (pointer: fine) {
      .description:hover .text,
      .description:hover .redirect-icon {
         color: var(--sl-color-accent);
         opacity: 1;
         transition: opacity 0.2s ease-in-out;
         cursor: pointer;
      }
   }
</style>
