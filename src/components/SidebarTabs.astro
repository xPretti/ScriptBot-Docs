---
// SidebarTabs.astro
interface TabItem {
   label: string;
   href: string;
}

interface Props {
   tabs: TabItem[];
}

const { tabs } = Astro.props;

// Obtém o caminho da URL atual (ex: "/demos" ou "/")
const pathname = Astro.url.pathname.replace(/\/$/, "");
---

<div class="custom-tabs-container">
   <ul
      role="tablist"
      class="tabs-list"
   >
      {
         tabs.map((tab) => {
            const tabHref = tab.href.replace(/\/$/, "");
            const isActive = pathname === tabHref || (pathname === "" && tabHref === "");

            return (
               <li
                  role="presentation"
                  class="tab-item"
               >
                  <a
                     href={tab.href}
                     role="tab"
                     aria-selected={isActive ? "true" : "false"}
                     class:list={["tab-link", { "is-active": isActive }]}
                  >
                     <span class="tab-label">{tab.label}</span>
                  </a>

                  {isActive && <div class="active-indicator" />}
               </li>
            );
         })
      }
   </ul>
</div>

<style>
   .custom-tabs-container {
      border-bottom: 1px solid var(--sl-color-gray-5);
      background-color: transparent;
   }

   .tabs-list {
      display: flex;
      gap: 1.5rem;
      list-style: none !important;
      margin: 0 !important;
      padding: 0 !important;
   }

   .tab-item {
      position: relative;
      display: flex;
      align-items: center;
   }

   .tab-link {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.75rem 0.25rem;
      font-size: 0.875rem;
      font-weight: 500;
      color: var(--sl-color-gray-3);
      text-decoration: none !important;
      transition: color 0.2s ease;
   }

   .tab-link:hover {
      color: var(--sl-color-accent);
   }

   .tab-link.is-active {
      color: var(--sl-color-accent);
   }

   .active-indicator {
      position: absolute;
      bottom: -1px;
      left: 0;
      width: 100%;
      height: 2px;
      background-color: var(--sl-color-accent);
      z-index: 1;
   }
</style>
