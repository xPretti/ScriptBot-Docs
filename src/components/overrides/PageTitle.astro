---
import { PAGE_TITLE_ID } from "node_modules/@astrojs/starlight/constants";

import { Breadcrumbs } from "astro-breadcrumbs";

import "astro-breadcrumbs/breadcrumbs.css";

import { ExternalLink } from "lucide-react";

const entry = Astro.locals.starlightRoute?.entry;
const pageLink = entry?.data?.pageLink;

const description = entry?.data?.description;
---

<Breadcrumbs
   truncated={true}
   customizeLinks={[{ index: 1, "aria-disabled": true }]}
>
   <svg
      slot="separator"
      xmlns="http://www.w3.org/2000/svg"
      width="24"
      height="24"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      ><polyline points="9 18 15 12 9 6"></polyline>
   </svg>

   <svg
      slot="ellipsis"
      xmlns="http://www.w3.org/2000/svg"
      width="24"
      height="24"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      ><circle
         cx="12"
         cy="12"
         r="1"
      ></circle><circle
         cx="19"
         cy="12"
         r="1"
      ></circle><circle
         cx="5"
         cy="12"
         r="1"
      ></circle></svg
   >
</Breadcrumbs>

<div class="pageTitle">
   <h1 id={PAGE_TITLE_ID}>{Astro.locals.starlightRoute.entry.data.title}</h1>
   {
      pageLink && (
         <a
            class="pageLink btn"
            href={pageLink.href}
         >
            <span class="label">{pageLink.label}</span>
            <div class="icon">
               <ExternalLink size={"100%"} />
            </div>
         </a>
      )
   }
</div>

{description && <p>{description}</p>}

<style>
   @layer starlight.core {
      h1 {
         margin-top: 1rem;
         font-size: var(--sl-text-h1);
         line-height: var(--sl-line-height-headings);
         font-weight: 600;
         color: var(--sl-color-white);
      }
   }

   .pageTitle {
      position: relative;
   }

   .pageTitle h1 {
      margin-top: 0;
   }

   .pageLink {
      display: flex;
      align-items: center;
      position: absolute;
      right: 0;
      top: 50%;
      transform: translateY(-50%);
   }

   .btn {
      text-decoration: none;
      font-weight: 400;
      padding: 0.25rem 0.5rem;
      border-radius: 0.4rem;
      color: var(--sl-color-white);
   }

   .btn:hover {
      background: none;
      color: var(--sl-color-accent);
   }

   .icon {
      display: inline-flex;
      margin-left: 0.5rem;
      width: 21px;
      height: 21px;
   }

   @media (max-width: 390px) {
      .label {
         display: none;
      }
      .icon {
         width: 24px;
         height: 24px;
      }
   }
</style>

<style is:global>
   .c-breadcrumbs__link[aria-disabled="true"] {
      pointer-events: none;
      cursor: default;
   }
</style>
