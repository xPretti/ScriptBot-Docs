<style is:global>
   .sl-heading-wrapper.highlighted-title * {
      color: var(--sl-color-accent-high);
   }
</style>

<script>
   function applyHeadingHighlight() {
      document.querySelectorAll(".sl-heading-wrapper.highlighted-title").forEach((el) => el.classList.remove("highlighted-title"));

      const hash = decodeURIComponent(window.location.hash);

      if (!hash) return;

      const heading = document.querySelector(hash);
      if (!heading) return;

      const wrapper = heading.closest(".sl-heading-wrapper");
      if (wrapper) wrapper.classList.add("highlighted-title");
   }

   window.addEventListener("hashchange", applyHeadingHighlight);
   window.addEventListener("popstate", applyHeadingHighlight);

   const observer = new MutationObserver(applyHeadingHighlight);

   observer.observe(document.body, {
      childList: true,
      subtree: true,
   });
</script>
