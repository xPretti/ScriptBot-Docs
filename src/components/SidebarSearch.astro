---
// SidebarSearch.astro
import { Search } from "lucide-react";
---

<div class="sidebar-search-container">
   <div class="search-wrapper">
      <span class="search-icon"><Search width={18} /></span>
      <input
         id="sidebar-search"
         type="text"
         placeholder="Pesquisar na barra lateral..."
         class="search-input"
         autocomplete="off"
      />
   </div>

   <div
      id="sidebar-no-results"
      class="no-results hidden"
   >
      <p>Nenhum resultado encontrado.</p>
      <button
         type="button"
         id="open-global-search"
         class="global-search-btn"
      >
         Pesquisar em todo o site
      </button>
   </div>

   <div class="sidebar-content">
      <slot />
   </div>
</div>

<style>
   .sidebar-search-container {
      display: flex;
      flex-direction: column;
   }
   .search-wrapper {
      position: relative;
      width: 100%;
   }
   .search-input {
      width: 100%;
      padding: 5px 40px 5px 12px;
      border-radius: 0.5rem;
      border: 1px solid var(--sl-color-gray-5);
      background-color: var(--sl-color-black);
      color: var(--sl-color-white);
      outline: none;
      font-size: var(--sl-text-sm);
   }
   .search-input:focus {
      border-color: var(--sl-color-accent);
   }
   .search-icon {
      position: absolute;
      right: 0.75rem;
      top: 50%;
      transform: translateY(-50%);
      opacity: 0.5;
      display: inline-flex;
      align-items: center;
   }
   .no-results {
      margin-top: 15px;
      padding: 1.5rem 1rem;
      text-align: center;
      font-size: var(--sl-text-xs);
      color: var(--sl-color-gray-3);
      border: 1px dashed var(--sl-color-gray-5);
      border-radius: 0.5rem;
   }
   .global-search-btn {
      background: none;
      border: none;
      color: var(--sl-color-accent);
      border-radius: 0.4rem;
      cursor: pointer;
      font-weight: 600;
      margin-top: 0;
   }
   .hidden {
      display: none !important;
   }
   :global(li.selected > a),
   :global(li.selected > summary .large) {
      color: var(--sl-color-accent-low) !important;
   }
</style>

<script type="module">
   // Variável fora da função init para persistir no ciclo de vida do ClientRouter
   let currentSearchQuery = "";

   const initSidebarSearch = () => {
      const searchInput = document.getElementById("sidebar-search");
      const noResults = document.getElementById("sidebar-no-results");
      const sidebarContent = document.querySelector(".sidebar-content .top-level");
      const globalSearchBtn = document.getElementById("open-global-search");

      if (!searchInput || !noResults || !sidebarContent) return;

      const detailsState = new Map();
      sidebarContent.querySelectorAll("details").forEach((d) => detailsState.set(d, d.open));

      const normalize = (t) =>
         t
            .toLowerCase()
            .normalize("NFD")
            .replace(/[\u0300-\u036f]/g, "");

      function performSearch(query) {
         // Atualiza a variável persistente na memória do navegador
         currentSearchQuery = query;

         const terms = query.trim().split(/\s+/).filter(Boolean).map(normalize);
         const allLi = sidebarContent.querySelectorAll("li");

         noResults.classList.add("hidden");

         if (!terms.length) {
            allLi.forEach((li) => {
               li.style.display = "";
               li.classList.remove("selected");
            });
            sidebarContent.querySelectorAll("details").forEach((d) => (d.open = detailsState.get(d)));
            return;
         }

         allLi.forEach((li) => {
            li.style.display = "none";
            li.classList.remove("selected");
         });

         let matched = false;
         terms.forEach((term) => {
            allLi.forEach((li) => {
               const text = normalize(li.querySelector("summary .large, a span")?.textContent || "");
               if (text.includes(term)) {
                  matched = true;
                  li.style.display = "";
                  li.classList.add("selected");
                  li.querySelectorAll("li").forEach((c) => (c.style.display = ""));
                  let p = li.parentElement;
                  while (p && p !== sidebarContent) {
                     if (p.tagName === "LI") p.style.display = "";
                     if (p.tagName === "DETAILS") p.open = true;
                     p = p.parentElement;
                  }
               }
            });
         });
         if (!matched) noResults.classList.remove("hidden");
      }

      // --- RECUPERAÇÃO DURANTE NAVEGAÇÃO ---
      if (currentSearchQuery) {
         searchInput.value = currentSearchQuery;
         performSearch(currentSearchQuery);
      }
      // -------------------------------------

      if (globalSearchBtn) {
         globalSearchBtn.addEventListener("click", (event) => {
            event.stopPropagation();
            const query = searchInput.value;
            const siteSearch = document.querySelector("site-search");
            const dialog = siteSearch?.querySelector("dialog");
            const frame = siteSearch?.querySelector(".dialog-frame");

            if (dialog && frame) {
               const closeOnOutsideClick = (e) => {
                  const isLink = "href" in (e.target || {});
                  const outsideFrame = document.body.contains(e.target) && !frame.contains(e.target);
                  if (isLink || outsideFrame) {
                     dialog.close();
                  }
               };

               dialog.showModal();
               document.body.toggleAttribute("data-search-modal-open", true);
               window.addEventListener("click", closeOnOutsideClick);

               dialog.addEventListener(
                  "close",
                  () => {
                     document.body.toggleAttribute("data-search-modal-open", false);
                     window.removeEventListener("click", closeOnOutsideClick);
                  },
                  { once: true },
               );

               const inject = () => {
                  const input = dialog.querySelector("input.pagefind-ui__search-input");
                  if (input) {
                     input.value = query;
                     input.dispatchEvent(new Event("input", { bubbles: true }));
                     input.focus();
                  } else {
                     setTimeout(inject, 50);
                  }
               };
               inject();
            }
         });
      }

      searchInput.addEventListener("input", (e) => performSearch(e.target.value));

      searchInput.addEventListener("keydown", (e) => {
         if (e.key === "Escape") {
            searchInput.value = "";
            performSearch("");
            searchInput.blur();
         }
      });

      const handleSlash = (e) => {
         const target = e.target;
         const isEditable = target instanceof Element && (["INPUT", "TEXTAREA", "SELECT"].includes(target.tagName) || target.isContentEditable);
         if (e.key === "/" && !isEditable) {
            e.preventDefault();
            searchInput.focus();
         }
      };

      document.removeEventListener("keydown", handleSlash, { capture: true });
      document.addEventListener("keydown", handleSlash, { capture: true });
   };

   document.addEventListener("astro:page-load", initSidebarSearch);
</script>
